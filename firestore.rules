// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Fields: uid, name, email, role, territories, active
//
// Collection: products
// Fields: sku, name, brand, category, mrp, ptr, pts, stock, reorderLevel
//
// Collection: customers
// Fields: id, name, type, address, location, beatId, creditLimit, outstanding
//
// Collection: orders
// Fields: id, customerId, salesRepId, items, totalAmount, status, createdAt
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Super Admin') || 
              (request.auth.token.email == "mrwater.prov1@gmail.com" && request.auth.token.email_verified == true));
    }

    function isManager() {
      return isAdmin() || hasRole('Distribution Manager') || hasRole('Sales Manager');
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string &&
             data.role in ["Super Admin", "Distribution Manager", "Sales Manager", "Sales Representative", "Warehouse Manager", "Warehouse Operator", "Accounts Executive", "MIS Analyst"];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Rules for Users
    match /users/{uid} {
      // Users can read their own profile, admins can read all
      allow read: if isOwner(uid) || isAdmin();
      
      // Allow self-creation on first login, or admin creation
      allow create: if (isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == 'Sales Representative') || isAdmin();
      
      // Only admins can update roles, users can update their own name
      allow update: if isAdmin() || (isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role);
    }

    // Rules for Products
    match /products/{sku} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Rules for Customers
    match /customers/{id} {
      allow read: if isAuthenticated();
      allow write: if isManager() || hasRole('Sales Representative');
    }

    // Rules for Orders
    match /orders/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isManager() || (hasRole('Sales Representative') && resource.data.salesRepId == request.auth.uid);
    }

    // Rules for Batches
    match /batches/{id} {
      allow read: if isAuthenticated();
      allow write: if isManager() || hasRole('Warehouse Manager');
    }

    // Rules for Movements
    match /movements/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Rules for Schemes
    match /schemes/{id} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // Rules for Companies
    match /companies/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
